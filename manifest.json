{
  "manifest_version": 3,
  "name": "Tab Organizer",
  "description": "Organize open tabs into local category-based groups.",
  "version": "0.1.0",
  "permissions": ["tabs", "tabGroups", "storage"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Tab Organizer",
    "default_popup": "src/popup/popup.html"
  }
}
